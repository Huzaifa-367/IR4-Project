APP_NAME=IR4
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://ir4.site.local

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_LEVEL=warning

# Production database is MySQL 8 only (DOC-20).
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ir4
DB_USERNAME=ir4_app
DB_PASSWORD=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=
REDIS_PORT=6379

MAIL_MAILER=log

BROADCAST_CONNECTION=reverb
REVERB_APP_ID=ir4
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=ir4.site.local
REVERB_PORT=443
REVERB_SCHEME=https
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# ZT411 — deploy-only (not runtime settings)
EQUIPMENT_PRINTER_HOST=192.168.10.50
EQUIPMENT_PRINTER_PORT=9100

# Separate volumes (DOC-19)
BACKUP_DISK=backups
BACKUP_DISK_ROOT=/mnt/ir4-backups
EXPORT_DISK=exports
EXPORT_DISK_ROOT=/mnt/ir4-backups/exports
BACKUP_ENCRYPTION_KEY=
BACKUP_MYSQLDUMP_PATH=/usr/bin/mysqldump
BACKUP_MYSQL_PATH=/usr/bin/mysql
DISK_SPACE_WARN_PCT=15
IR4_WIPE_MODE=crypto_erase

# Lifecycle connections (DOC-19/20)
IR4_BACKUP_CONNECTION=ir4_backup
IR4_BACKUP_DB_HOST=127.0.0.1
IR4_BACKUP_DB_PORT=3306
IR4_BACKUP_DB_DATABASE=ir4
IR4_BACKUP_DB_USERNAME=ir4_backup
IR4_BACKUP_DB_PASSWORD=

IR4_RESTORE_CONNECTION=ir4_restore
IR4_RESTORE_DB_DRIVER=mysql
IR4_RESTORE_DB_HOST=127.0.0.1
IR4_RESTORE_DB_PORT=3306
IR4_RESTORE_DB_DATABASE=ir4_restore
IR4_RESTORE_DB_USERNAME=ir4_restore
IR4_RESTORE_DB_PASSWORD=

IR4_WIPE_CONNECTION=ir4_wipe
IR4_WIPE_DB_HOST=127.0.0.1
IR4_WIPE_DB_PORT=3306
IR4_WIPE_DB_DATABASE=ir4
IR4_WIPE_DB_USERNAME=ir4_wipe
IR4_WIPE_DB_PASSWORD=
